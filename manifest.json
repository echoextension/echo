{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.3.2",
  "default_locale": "zh_CN",
  "homepage_url": "https://www.echoextension.com",
  "description": "__MSG_extDescription__",
  "permissions": ["tabs", "storage", "downloads", "scripting", "declarativeNetRequest"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "net_rules.json"
      }
    ]
  },
  "action": {
    "default_title": "ECHO 设置",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "ntp/ntp.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "search-box/search-box.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["bili-tool/bili-tool.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options/options.html",
  "commands": {
    "boss-key": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "windows": "Ctrl+Q",
        "mac": "Ctrl+Shift+Q"
      },
      "description": "老板键 - 最小化/恢复所有窗口"
    },
    "toggle-mute": {
      "suggested_key": {
        "default": "Alt+M",
        "windows": "Alt+M",
        "mac": "Alt+M"
      },
      "description": "一键静音/取消静音"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*", "wallpaper/*", "icons/*", "docs-viewer.html", "*.md"],
      "matches": ["<all_urls>"]
    }
  ]
}
